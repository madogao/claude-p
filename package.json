{
  "name": "claude-p",
  "version": "0.0.3",
  "description": "Drop-in replacement for `claude -p` that drives the interactive `claude` UI inside an in-process zmux PTY session.",
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "cli",
    "zig",
    "pty",
    "zmux"
  ],
  "license": "MIT",
  "author": "William Cory <will@tevm.tech>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smithersai/claude-p.git"
  },
  "homepage": "https://github.com/smithersai/claude-p#readme",
  "bugs": {
    "url": "https://github.com/smithersai/claude-p/issues"
  },
  "bin": {
    "claude-p": "bin/claude-p.js"
  },
  "files": [
    "bin/claude-p.js",
    "scripts/install.js",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "postinstall": "node scripts/install.js",
    "test": "zig build test",
    "build": "zig build -Doptimize=ReleaseSafe",
    "release": "node scripts/publish.mjs",
    "release:dry-run": "node scripts/publish.mjs --dry-run",
    "release:local": "node scripts/publish.mjs --local-only"
  },
  "os": [
    "darwin",
    "linux"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "engines": {
    "node": ">=18"
  }
}
